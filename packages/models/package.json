{
  "name": "@canirun/models",
  "version": "0.1.0",
  "description": "Curated local AI model catalog and quantization metadata for CanIRun.ai",
  "type": "module",
  "packageManager": "pnpm@11.1.3",
  "sideEffects": false,
  "homepage": "https://canirun.ai",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/midudev/canirun.ai.git",
    "directory": "packages/models"
  },
  "bugs": {
    "url": "https://github.com/midudev/canirun.ai/issues"
  },
  "keywords": [
    "ai",
    "models",
    "llm",
    "gguf",
    "canirun"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "development": "./src/index.ts",
      "source": "./src/index.ts",
      "import": "./dist/index.js"
    },
    "./gguf-sizes.json": {
      "development": "./src/gguf-sizes.json",
      "source": "./src/gguf-sizes.json",
      "default": "./dist/gguf-sizes.json"
    }
  },
  "files": [
    "src",
    "dist"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "prepack": "pnpm run build"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "typescript": "6.0.3"
  }
}
