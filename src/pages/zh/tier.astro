  .tier-row {
    background-color: var(--color-surface);
  }

  .tier-row:nth-child(odd) {
    background-color: var(--color-surface-card);
  }

  .tier-chip {
    backdrop-filter: none;
  }

  @media (max-width: 640px) {
    .tier-label {
      writing-mode: horizontal-tb;
    }
  }
</style>
