---
import Layout from "@/layouts/Layout.astro";
import NavHeader from "./components/NavHeader.astro";
import Footer from "./components/Footer.astro";
import { models } from "@/data/models";
import IconDownload from "@/icons/download.svg";
import IconCopy from "@/icons/copy.svg";
---

<Layout title="分级列表 — CanIRun.ai" description="See which AI models your machine can run, ranked in a classic tier list. Share your results.">
  <NavHeader />
  <main class="mx-auto max-w-5xl px-4 py-10 sm:px-6">
    <header class="mb-6 text-center">
      <h1 class="font-pixel text-3xl tracking-tight text-accent sm:text-4xl">分级列表</h1>
      <p class="mt-2 text-base text-muted">你的硬件 vs 每个模型。经典分级列表格式。</p>
    </header>

    <!-- 硬件信息 -->
    <div class="mb-6 flex flex-wrap items-center justify-center gap-x-3 gap-y-1.5 font-mono text-sm text-secondary">
      <select id="hw-device-select" class="hw-editable-select text-muted" disabled>
        <option value="">检测硬件中...</option>
      </select>
      <span id="hw-ram-group" class="hidden inline-flex items-center">
        <span class="text-edge/40 mr-2">·</span>
        <span data-tooltip="VRAM — 用于加载模型的显存。在 Apple Silicon/iGPU 上，它与系统内存共享" data-tooltip-pos="bottom" tabindex="0" aria-label="VRAM 信息" class="mr-1 inline-flex cursor-help text-muted" id="hw-vram-label">显存</span>
        <select id="hw-ram-select" class="hw-editable-select"></select>
      </span>
      <span id="hw-sysram-group" class="hidden inline-flex items-center">
        <span class="text-edge/40 mr-2">·</span>
        <span data-tooltip="系统内存 — 当模型无法放入 VRAM 时用于 CPU 卸载" data-tooltip-pos="bottom" tabindex="0" aria-label="系统内存信息" class="mr-1 inline-flex cursor-help text-muted">内存</span>
        <select id="hw-sysram-select" class="hw-editable-select"></select>
      </span>
      <span id="hw-bw-group" class="hidden inline-flex items-center">
        <span class="text-edge/40 mr-2">·</span>
        <span data-tooltip="GB/s — 内存带宽。数据传送到处理器的速度。越高 = 推理越快" data-tooltip-pos="bottom" tabindex="0" aria-label="带宽信息" class="mr-1 inline-flex cursor-help text-muted">BW</span>
        <select id="hw-bw-select" class="hw-editable-select"></select>
      </span>
      <span id="hw-cores-group" class="hidden inline-flex items-center">
        <span class="text-edge/40 mr-2">·</span>
        <span id="hw-gpu-cores-text" class="text-secondary"></span>
      </span>
    </div>

    <!-- 配置面板 -->
    <div class="mb-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-2 font-mono text-[13px] text-secondary">
      <label class="inline-flex cursor-pointer items-center gap-1.5 select-none">
        <input type="checkbox" id="opt-toks" checked class="tier-check accent-accent" />
        Tokens/s
      </label>
      <label class="inline-flex cursor-pointer items-center gap-1.5 select-none">
        <input type="checkbox" id="opt-provider" class="tier-check accent-accent" />
        厂商
      </label>
      <label class="inline-flex cursor-pointer items-center gap-1.5 select-none">
        <input type="checkbox" id="opt-vram" class="tier-check accent-accent" />
        VRAM
      </label>
      <label class="inline-flex cursor-pointer items-center gap-1.5 select-none">
        <input type="checkbox" id="opt-popular" checked class="tier-check accent-accent" />
        仅热门
      </label>
      <label class="inline-flex cursor-pointer items-center gap-1.5 select-none">
        <input type="checkbox" id="opt-hide-f" class="tier-check accent-accent" />
        隐藏 F 级
      </label>
      <span class="text-edge/40">|</span>
      <label class="inline-flex cursor-pointer items-center gap-1.5 select-none">
        排序：
        <select id="opt-sort" class="rounded border border-edge bg-surface-card px-1.5 py-0.5 text-[13px] text-secondary outline-none">
          <option value="score">评分</option>
          <option value="name">名称</option>
          <option value="params">参数</option>
          <option value="toks">速度</option>
        </select>
      </label>
    </div>

    <!-- 分享按钮 -->
    <div class="mb-8 flex justify-center gap-3">
      <button id="share-btn" class="inline-flex items-center gap-2 rounded-md border border-edge bg-surface-card px-4 py-2 font-mono text-[13px] text-secondary transition-colors hover:border-accent/30 hover:text-accent disabled:opacity-40 disabled:cursor-not-allowed" disabled>
        <IconDownload class="h-3.5 w-3.5" />
        下载为图片
      </button>
      <button id="copy-btn" class="inline-flex items-center gap-2 rounded-md border border-edge bg-surface-card px-4 py-2 font-mono text-[13px] text-secondary transition-colors hover:border-accent/30 hover:text-accent disabled:opacity-40 disabled:cursor-not-allowed" disabled>
        <IconCopy class="h-3.5 w-3.5" />
        复制到剪贴板
      </button>
    </div>

    <!-- 分级列表容器 -->
    <div id="tier-list" class="tier-list-container overflow-hidden rounded-xl border border-edge">
      <!-- 图片导出水印头部 -->
      <div class="flex items-center justify-between bg-surface-card px-4 py-3 border-b border-edge">
        <span class="font-pixel text-base text-accent">CanIRun.ai</span>
        <span id="tier-hw-label" class="font-mono text-xs text-muted"></span>
      </div>

      {/* Model data embedded for JS */}
      <script id="models-data" type="application/json" set:html={JSON.stringify(models.map(m => ({
        id: m.id,
        name: m.name,
        provider: m.provider,
        params: m.params,
        paramsBillions: m.paramsBillions,
        architecture: m.architecture,
        vramQ4: m.quants.find(q => q.name === "Q4_K_M")?.vramGB || m.quants[0].vramGB,
        featured: m.featured || false,
      })))} />

      <!-- S Tier -->
      <div class="tier-row flex border-b border-edge/50">
        <div class="tier-label flex w-16 shrink-0 items-center justify-center font-pixel text-2xl sm:w-20 sm:text-3xl" style="background-color: rgba(34,197,94,0.15); color: #22c55e;" data-tooltip="显存充足，推理速度快" tabindex="0" aria-label="S 级：运行流畅">S</div>
        <div id="tier-s" class="tier-items flex min-h-[64px] flex-1 flex-wrap items-center gap-1.5 p-2"></div>
      </div>

      <!-- A Tier -->
      <div class="tier-row flex border-b border-edge/50">
        <div class="tier-label flex w-16 shrink-0 items-center justify-center font-pixel text-2xl sm:w-20 sm:text-3xl" style="background-color: rgba(74,222,128,0.15); color: #4ade80;" data-tooltip="运行流畅，余量充足" tabindex="0" aria-label="A 级：运行良好">A</div>
        <div id="tier-a" class="tier-items flex min-h-[64px] flex-1 flex-wrap items-center gap-1.5 p-2"></div>
      </div>

      <!-- B Tier -->
      <div class="tier-row flex border-b border-edge/50">
        <div class="tier-label flex w-16 shrink-0 items-center justify-center font-pixel text-2xl sm:w-20 sm:text-3xl" style="background-color: rgba(163,230,53,0.15); color: #a3e635;" data-tooltip="性能尚可，内存占用较高" tabindex="0" aria-label="B 级：尚可">B</div>
        <div id="tier-b" class="tier-items flex min-h-[64px] flex-1 flex-wrap items-center gap-1.5 p-2"></div>
      </div>

      <!-- C Tier -->
      <div class="tier-row flex border-b border-edge/50">
        <div class="tier-label flex w-16 shrink-0 items-center justify-center font-pixel text-2xl sm:w-20 sm:text-3xl" style="background-color: rgba(245,158,11,0.15); color: #f59e0b;" data-tooltip="勉强运行，推理速度较慢" tabindex="0" aria-label="C 级：勉强运行">C</div>
        <div id="tier-c" class="tier-items flex min-h-[64px] flex-1 flex-wrap items-center gap-1.5 p-2"></div>
      </div>

      <!-- D Tier -->
      <div class="tier-row flex border-b border-edge/50">
        <div class="tier-label flex w-16 shrink-0 items-center justify-center font-pixel text-2xl sm:w-20 sm:text-3xl" style="background-color: rgba(249,115,22,0.15); color: #f97316;" data-tooltip="几乎无法运行，推理极慢" tabindex="0" aria-label="D 级：几乎无法运行">D</div>
        <div id="tier-d" class="tier-items flex min-h-[64px] flex-1 flex-wrap items-center gap-1.5 p-2"></div>
      </div>

      <!-- F Tier -->
      <div class="tier-row flex">
        <div class="tier-label flex w-16 shrink-0 items-center justify-center font-pixel text-2xl sm:w-20 sm:text-3xl" style="background-color: rgba(239,68,68,0.15); color: #ef4444;" data-tooltip="内存不足，无法运行此模型" tabindex="0" aria-label="F 级：太重了">F</div>
        <div id="tier-f" class="tier-items flex min-h-[64px] flex-1 flex-wrap items-center gap-1.5 p-2"></div>
      </div>

      <!-- 页脚水印 -->
      <div class="flex items-center justify-between bg-surface-card px-4 py-2 border-t border-edge">
        <span class="font-mono text-[13px] text-secondary">在 <span class="text-accent">canirun.ai/tier</span> 创建你自己的</span>
        <span class="font-mono text-xs text-muted">Q4_K_M quantization</span>
      </div>
    </div>

    <!-- 图例 -->
    <div class="mt-6 flex flex-wrap items-center justify-center gap-x-5 gap-y-1 font-mono text-xs text-muted">
      <span><span class="font-pixel" style="color:#22c55e">S</span> 运行流畅</span>
      <span><span class="font-pixel" style="color:#4ade80">A</span> 运行良好</span>
      <span><span class="font-pixel" style="color:#a3e635">B</span> 尚可</span>
      <span><span class="font-pixel" style="color:#f59e0b">C</span> 勉强运行</span>
      <span><span class="font-pixel" style="color:#f97316">D</span> 几乎无法运行</span>
      <span><span class="font-pixel" style="color:#ef4444">F</span> 太重了</span>
    </div>

    <p class="mt-3 text-center text-xs text-muted">
      基于 Q4_K_M 量化。实际结果可能有所不同。
    </p>

    <Footer />
  </main>
</Layout>

<script>
  import { detectHardware, evaluateModelComplete, cleanGPUName, getDisplayName, getHardwareOverrides, saveHardwareOverrides, applyOverrides, getDeviceOverrides, RAM_OPTIONS, BW_OPTIONS, GRADES } from "@/lib/hardware";
  import type { HardwareInfo, HardwareOverrides } from "@/lib/hardware";
  import { fitSelectWidth, populateSelect, appendDeviceOptgroups } from "@/lib/hardware-ui";

  interface TierModel {
    id: string;
    name: string;
    provider: string;
    params: string;
    paramsBillions: number;
    architecture: string;
    vramQ4: number;
    featured: boolean;
  }

  interface EvalResult {
    model: TierModel;
    grade: string;
    score: number;
    toks: number | null;
  }

  const TIER_COLORS: Record<string, string> = {
    S: "#22c55e",
    A: "#4ade80",
    B: "#a3e635",
    C: "#f59e0b",
    D: "#f97316",
    F: "#ef4444",
  };

  // ── Config ──────────────────────────────────────────────

  function getConfig() {
    return {
      showToks: (document.getElementById("opt-toks") as HTMLInputElement).checked,
      showProvider: (document.getElementById("opt-provider") as HTMLInputElement).checked,
      showVram: (document.getElementById("opt-vram") as HTMLInputElement).checked,
      onlyPopular: (document.getElementById("opt-popular") as HTMLInputElement).checked,
      hideF: (document.getElementById("opt-hide-f") as HTMLInputElement).checked,
      sort: (document.getElementById("opt-sort") as HTMLSelectElement).value,
    };
  }

  // ── Chip creation ───────────────────────────────────────

  function createModelChip(model: TierModel, grade: string, score: number, toks: number | null, config: ReturnType<typeof getConfig>): HTMLElement {
    const chip = document.createElement("a");
    chip.href = `/model/${model.id}`;
    chip.className = "tier-chip group relative flex items-center gap-1.5 rounded-md border px-2.5 py-1.5 font-mono text-[13px] transition-colors hover:bg-surface-hover";
    const color = TIER_COLORS[grade] || "#56565f";
    // Use hex+alpha instead of color-mix for html2canvas compatibility
    chip.style.borderColor = `${color}4D`; // 30% opacity
    chip.style.backgroundColor = `${color}0D`; // 5% opacity

    const dot = document.createElement("span");
    dot.className = "h-1.5 w-1.5 rounded-full shrink-0";
    dot.style.backgroundColor = color;

    const name = document.createElement("span");
    name.className = "text-primary truncate max-w-[120px] sm:max-w-[160px]";
    name.textContent = model.name;

    chip.appendChild(dot);
    chip.appendChild(name);

    if (config.showProvider) {
      const prov = document.createElement("span");
      prov.className = "text-muted/50 text-[11px] shrink-0";
      prov.textContent = model.provider;
      chip.appendChild(prov);
    }

    const meta = document.createElement("span");
    meta.className = "text-muted text-[11px] shrink-0";
    meta.textContent = model.params;
    chip.appendChild(meta);

    if (config.showVram) {
      const vramSpan = document.createElement("span");
      vramSpan.className = "text-muted/50 text-[11px] shrink-0";
      vramSpan.textContent = `${model.vramQ4}GB`;
      chip.appendChild(vramSpan);
    }

    if (config.showToks && toks !== null && grade !== "F") {
      const tokSpan = document.createElement("span");
      tokSpan.className = "text-[11px] shrink-0";
      tokSpan.style.color = color;
      tokSpan.textContent = `${toks}t/s`;
      chip.appendChild(tokSpan);
    }

    return chip;
  }

  // ── Render tier list ────────────────────────────────────

  let evaluatedModels: EvalResult[] = [];

  function renderTierList() {
    const config = getConfig();

    const containers: Record<string, HTMLElement> = {
      S: document.getElementById("tier-s")!,
      A: document.getElementById("tier-a")!,
      B: document.getElementById("tier-b")!,
      C: document.getElementById("tier-c")!,
      D: document.getElementById("tier-d")!,
      F: document.getElementById("tier-f")!,
    };

    // Clear all
    for (const container of Object.values(containers)) {
      container.innerHTML = "";
    }

    // Sort
    const sorted = [...evaluatedModels];
    switch (config.sort) {
      case "name":
        sorted.sort((a, b) => a.model.name.localeCompare(b.model.name));
        break;
      case "params":
        sorted.sort((a, b) => a.model.paramsBillions - b.model.paramsBillions);
        break;
      case "toks":
        sorted.sort((a, b) => (b.toks ?? 0) - (a.toks ?? 0));
        break;
      default: // score
        sorted.sort((a, b) => b.score - a.score || a.model.paramsBillions - b.model.paramsBillions);
    }

    // Hide/show F tier row
    const fRow = document.getElementById("tier-f")!.closest(".tier-row") as HTMLElement;
    if (fRow) fRow.style.display = config.hideF ? "none" : "";

    // Place chips
    for (const { model, grade, score, toks } of sorted) {
      const g = grade === "?" ? "F" : grade;
      if (config.hideF && g === "F") continue;
      if (config.onlyPopular && !model.featured) continue;
      const container = containers[g];
      if (container) {
        container.appendChild(createModelChip(model, g, score, toks, config));
      }
    }

    // Add empty state
    for (const [key, container] of Object.entries(containers)) {
      if (config.hideF && key === "F") continue;
      if (container.children.length === 0) {
        const empty = document.createElement("span");
        empty.className = "text-xs text-muted/30 font-mono italic px-2";
        empty.textContent = "—";
        container.appendChild(empty);
      }
    }
  }

  // ── Init ────────────────────────────────────────────────

  let detectedHW: HardwareInfo;
  let currentHW: HardwareInfo;
  let modelsData: TierModel[] = [];

  function populateDeviceSelect(select: HTMLSelectElement, detectedName: string, storedDevice: string | undefined) {
    select.innerHTML = "";
    const autoOpt = document.createElement("option");
    autoOpt.value = "auto";
    autoOpt.textContent = `${detectedName} ✱`;
    select.appendChild(autoOpt);

    const customOpt = document.createElement("option");
    customOpt.value = "custom";
    customOpt.textContent = "Custom";
    select.appendChild(customOpt);

    appendDeviceOptgroups(select, storedDevice);

    select.value = storedDevice || "auto";
    select.disabled = false;
    select.classList.remove("text-muted");
    select.classList.add("text-secondary");
    fitSelectWidth(select);
  }

  function updateHardwareBar(hw: HardwareInfo) {
    const overrides = getHardwareOverrides();

    const deviceSelect = document.getElementById("hw-device-select") as HTMLSelectElement;
    if (deviceSelect) {
      populateDeviceSelect(deviceSelect, getDisplayName(detectedHW), overrides.device);
    }

    const vramLabel = document.getElementById("hw-vram-label");
    if (vramLabel) vramLabel.textContent = "VRAM";

    const effectiveRam = hw.ramGB ?? hw.totalUsableRAM;
    if (effectiveRam) {
      document.getElementById("hw-ram-group")!.classList.remove("hidden");
      populateSelect(
        document.getElementById("hw-ram-select") as HTMLSelectElement,
        RAM_OPTIONS, detectedHW.ramGB, overrides.ramGB ?? effectiveRam, (v) => `${v} GB`
      );
    } else {
      document.getElementById("hw-ram-group")!.classList.add("hidden");
    }

    const sysramGroup = document.getElementById("hw-sysram-group");
    const sysramSelect = document.getElementById("hw-sysram-select") as HTMLSelectElement;
    const sysramLabel = sysramGroup?.querySelector("[data-tooltip]") as HTMLElement | null;
    if (sysramGroup && sysramSelect) {
      if (hw.isMobile) {
        sysramGroup.classList.add("hidden");
      } else if (hw.isAppleSilicon) {
        sysramGroup.classList.remove("hidden");
        sysramSelect.innerHTML = "";
        const opt = document.createElement("option");
        opt.value = "";
        opt.textContent = `${hw.totalUsableRAM ?? "—"} GB`;
        sysramSelect.appendChild(opt);
        sysramSelect.disabled = true;
        sysramSelect.classList.add("opacity-50", "cursor-not-allowed");
        fitSelectWidth(sysramSelect);
        if (sysramLabel) {
          sysramLabel.setAttribute("data-tooltip", "Unified memory — Apple Silicon shares RAM between CPU and GPU. No separate system RAM available for offloading");
        }
      } else {
        sysramGroup.classList.remove("hidden");
        sysramSelect.disabled = false;
        sysramSelect.classList.remove("opacity-50", "cursor-not-allowed");
        const raw = detectedHW.deviceMemoryRaw;
        const isGte8 = raw === null || raw >= 8;
        const selected = overrides.systemRAM ?? hw.systemRAM ?? 16;

        sysramSelect.innerHTML = "";
        const optGte8 = document.createElement("option");
        optGte8.value = "16";
        optGte8.textContent = isGte8 ? "≥8 GB ✱" : "≥8 GB";
        sysramSelect.appendChild(optGte8);

        const optLt8 = document.createElement("option");
        optLt8.value = "4";
        optLt8.textContent = !isGte8 ? "<8 GB ✱" : "<8 GB";
        sysramSelect.appendChild(optLt8);

        const sep = document.createElement("option");
        sep.disabled = true;
        sep.textContent = "───";
        sysramSelect.appendChild(sep);

        for (const v of [8, 16, 32, 64, 128]) {
          const opt = document.createElement("option");
          opt.value = String(v);
          opt.textContent = `${v} GB`;
          sysramSelect.appendChild(opt);
        }

        sysramSelect.value = String(selected);
        fitSelectWidth(sysramSelect);
        if (sysramLabel) {
          sysramLabel.setAttribute("data-tooltip", "系统内存 — 当模型无法放入 VRAM 时用于 CPU 卸载. More RAM = bigger models via offloading (slower)");
        }
      }
    }

    const effectiveBw = hw.memoryBandwidth;
    if (effectiveBw) {
      document.getElementById("hw-bw-group")!.classList.remove("hidden");
      populateSelect(
        document.getElementById("hw-bw-select") as HTMLSelectElement,
        BW_OPTIONS, detectedHW.memoryBandwidth, overrides.memoryBandwidth ?? effectiveBw, (v) => `~${v} GB/s`
      );
    } else {
      document.getElementById("hw-bw-group")!.classList.add("hidden");
    }

    if (hw.gpuCores) {
      document.getElementById("hw-cores-group")!.classList.remove("hidden");
      document.getElementById("hw-gpu-cores-text")!.textContent = `${hw.gpuCores.toLocaleString()} cores`;
    } else {
      document.getElementById("hw-cores-group")!.classList.add("hidden");
    }

    const parts: string[] = [getDisplayName(hw)];
    if (hw.ramGB) parts.push(`${hw.ramGB} GB VRAM`);
    if (hw.systemRAM && !hw.isAppleSilicon && !hw.isMobile) parts.push(`${hw.systemRAM} GB RAM`);
    if (hw.isAppleSilicon && hw.totalUsableRAM) parts.push(`${hw.totalUsableRAM} GB unified`);
    if (hw.memoryBandwidth) parts.push(`~${hw.memoryBandwidth} GB/s`);
    if (hw.gpuCores) parts.push(`${hw.gpuCores.toLocaleString()} cores`);
    document.getElementById("tier-hw-label")!.textContent = parts.join(" | ");
  }

  function evaluateAndRender() {
    evaluatedModels = modelsData.map(m => {
      const { grade, score, toksPerSec: toks } = evaluateModelComplete(m.vramQ4, currentHW, m.paramsBillions);
      return { model: m, grade, score, toks };
    });
    renderTierList();
  }

  function handleDeviceChange(deviceKey: string) {
    if (deviceKey === "auto") {
      saveHardwareOverrides({});
      currentHW = { ...detectedHW };
      updateHardwareBar(currentHW);
      evaluateAndRender();
      return;
    }
    if (deviceKey === "custom") {
      const prev = getHardwareOverrides();
      prev.device = "custom";
      saveHardwareOverrides(prev);
      return;
    }
    const deviceOverrides = getDeviceOverrides(deviceKey);
    if (!deviceOverrides) return;
    const prev = getHardwareOverrides();
    if (prev.systemRAM !== undefined) deviceOverrides.systemRAM = prev.systemRAM;
    saveHardwareOverrides(deviceOverrides);
    currentHW = applyOverrides(detectedHW, deviceOverrides);
    updateHardwareBar(currentHW);
    evaluateAndRender();
  }

  function setupHardwareEditing() {
    const deviceSelect = document.getElementById("hw-device-select") as HTMLSelectElement;
    const ramSelect = document.getElementById("hw-ram-select") as HTMLSelectElement;
    const sysramSelect = document.getElementById("hw-sysram-select") as HTMLSelectElement;
    const bwSelect = document.getElementById("hw-bw-select") as HTMLSelectElement;

    deviceSelect?.addEventListener("change", () => {
      handleDeviceChange(deviceSelect.value);
    });

    function handleFieldChange() {
      const overrides = getHardwareOverrides();
      if (ramSelect?.value) overrides.ramGB = Number(ramSelect.value);
      if (sysramSelect?.value) overrides.systemRAM = Number(sysramSelect.value);
      if (bwSelect?.value) overrides.memoryBandwidth = Number(bwSelect.value);
      if (!overrides.device || overrides.device === "auto") {
        overrides.device = "custom";
        const ds = document.getElementById("hw-device-select") as HTMLSelectElement;
        if (ds) { ds.value = "custom"; fitSelectWidth(ds); }
      }
      saveHardwareOverrides(overrides);
      currentHW = applyOverrides(detectedHW, overrides);
      updateHardwareBar(currentHW);
      evaluateAndRender();
    }

    ramSelect?.addEventListener("change", () => { handleFieldChange(); fitSelectWidth(ramSelect); });
    sysramSelect?.addEventListener("change", () => { handleFieldChange(); fitSelectWidth(sysramSelect); });
    bwSelect?.addEventListener("change", () => { handleFieldChange(); fitSelectWidth(bwSelect); });
  }

  async function init() {
    modelsData = JSON.parse(document.getElementById("models-data")!.textContent || "[]");
    detectedHW = await detectHardware();
    currentHW = applyOverrides(detectedHW);

    updateHardwareBar(currentHW);
    evaluateAndRender();

    document.getElementById("share-btn")!.removeAttribute("disabled");
    document.getElementById("copy-btn")!.removeAttribute("disabled");

    document.querySelectorAll(".tier-check, #opt-sort").forEach(el => {
      el.addEventListener("change", renderTierList);
    });
  }

  // ── Image export (snapdom) ────────────────────────────────

  import { snapdom } from "@zumer/snapdom";

  function setButtonLoading(btn: HTMLElement) {
    const original = btn.innerHTML;
    btn.innerHTML = `<svg class="h-3.5 w-3.5 animate-spin" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 2v4m0 12v4m-7.07-3.93l2.83-2.83m8.49-8.49l2.83-2.83M2 12h4m12 0h4m-3.93 7.07l-2.83-2.83M7.76 7.76L4.93 4.93"></path></svg>Generating...`;
    btn.setAttribute("disabled", "true");
    return original;
  }

  function restoreButton(btn: HTMLElement, html: string, delay = 0) {
    if (delay) {
      setTimeout(() => { btn.innerHTML = html; btn.removeAttribute("disabled"); }, delay);
    } else {
      btn.innerHTML = html;
      btn.removeAttribute("disabled");
    }
  }

  document.addEventListener('astro:page-load', () => {
    if (!document.getElementById('tier-list')) return;

    evaluatedModels = [];
    setupHardwareEditing();

    document.getElementById("share-btn")!.addEventListener("click", async () => {
      const btn = document.getElementById("share-btn")!;
      const originalHTML = setButtonLoading(btn);

      try {
        const element = document.getElementById("tier-list")!;
        await snapdom.download(element, {
          scale: 2,
          backgroundColor: document.documentElement.classList.contains("light") ? "#ffffff" : "#000000",
          embedFonts: true,
          filename: "canirun-tier-list",
          type: "png",
        });
      } catch (e) {
        console.error("Failed to generate image:", e);
      } finally {
        restoreButton(btn, originalHTML);
      }
    });

    document.getElementById("copy-btn")!.addEventListener("click", async () => {
      const btn = document.getElementById("copy-btn")!;
      const originalHTML = setButtonLoading(btn);

      try {
        const element = document.getElementById("tier-list")!;
        const blob = await snapdom.toBlob(element, {
          scale: 2,
          backgroundColor: document.documentElement.classList.contains("light") ? "#ffffff" : "#000000",
          embedFonts: true,
          type: "png",
        });

        try {
          await navigator.clipboard.write([
            new ClipboardItem({ "image/png": blob }),
          ]);
          btn.innerHTML = `<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Copied!`;
          restoreButton(btn, originalHTML, 2000);
        } catch {
          await snapdom.download(element, {
            scale: 2,
            backgroundColor: document.documentElement.classList.contains("light") ? "#ffffff" : "#000000",
            embedFonts: true,
            filename: "canirun-tier-list",
            type: "png",
          });
          btn.innerHTML = `<svg class="h-3.5 w-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>Downloaded!`;
          restoreButton(btn, originalHTML, 2000);
        }
      } catch (e) {
        console.error("Failed to generate image:", e);
        restoreButton(btn, originalHTML);
      }
    });

    init();
  });
</script>

