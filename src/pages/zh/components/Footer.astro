---
interface Props {
  class?: string;
}

const { class: className = "mt-16" } = Astro.props;
const hasSlot = Astro.slots.has("default");
const githubUrl = "https://github.com/midudev/canirun.ai";
---

<footer class:list={["text-center", className]}>
  <p class="text-sm text-primary inline-flex flex-wrap items-center justify-center gap-1">
    Built by <a href="https://midu.dev" target="_blank" rel="noopener" class="text-primary underline decoration-edge underline-offset-2 hover:text-accent">midudev</a> for the local AI community
    <svg width="13" height="12" viewBox="0 0 13 12" fill="none" xmlns="http://www.w3.org/2000/svg" class="inline-block" aria-hidden="true">
      <rect x="2" y="0" width="3" height="1" fill="#ef4444"/>
      <rect x="8" y="0" width="3" height="1" fill="#ef4444"/>
      <rect x="1" y="1" width="5" height="1" fill="#ef4444"/>
      <rect x="7" y="1" width="5" height="1" fill="#ef4444"/>
      <rect x="0" y="2" width="13" height="1" fill="#ef4444"/>
      <rect x="0" y="3" width="13" height="1" fill="#ef4444"/>
      <rect x="0" y="4" width="13" height="1" fill="#ef4444"/>
      <rect x="1" y="5" width="11" height="1" fill="#ef4444"/>
      <rect x="2" y="6" width="9" height="1" fill="#ef4444"/>
      <rect x="3" y="7" width="7" height="1" fill="#ef4444"/>
      <rect x="4" y="8" width="5" height="1" fill="#ef4444"/>
      <rect x="5" y="9" width="3" height="1" fill="#ef4444"/>
      <rect x="6" y="10" width="1" height="1" fill="#ef4444"/>
    </svg>
    <span class="mx-1 text-muted/50" aria-hidden="true">·</span>
    <a
      href={githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="inline-flex items-center gap-1 text-primary underline decoration-edge underline-offset-2 hover:text-accent"
      aria-label="打开 GitHub 仓库"
    >
      <svg class="size-4" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
        <polygon points="23 9 23 15 22 15 22 17 21 17 21 19 20 19 20 20 19 20 19 21 18 21 18 22 16 22 16 23 15 23 15 18 14 18 14 17 15 17 15 16 17 16 17 15 18 15 18 14 19 14 19 9 18 9 18 6 16 6 16 7 15 7 15 8 14 8 14 7 10 7 10 8 9 8 9 7 8 7 8 6 6 6 6 9 5 9 5 14 6 14 6 15 7 15 7 16 9 16 9 18 7 18 7 17 6 17 6 16 4 16 4 17 5 17 5 19 6 19 6 20 9 20 9 23 8 23 8 22 6 22 6 21 5 21 5 20 4 20 4 19 3 19 3 17 2 17 2 15 1 15 1 9 2 9 2 7 3 7 3 5 4 5 4 4 5 4 5 3 7 3 7 2 9 2 9 1 15 1 15 2 17 2 17 3 19 3 19 4 20 4 20 5 21 5 21 7 22 7 22 9 23 9"/>
      </svg>
      GitHub
    </a>
  </p>

  {hasSlot && (
    <div class="mt-3">
      <slot />
    </div>
  )}

  <p class="mt-2 text-[13px] text-muted/70 max-w-xl mx-auto leading-relaxed">
    所有产品名称、标志和品牌均为其各自所有者的财产。本网站提及的 Apple、NVIDIA、AMD、Intel、Qualcomm 及所有 AI 模型名称均为其各自持有者的商标或注册商标。本网站不与这些公司关联或获得其认可。
  </p>
</footer>
