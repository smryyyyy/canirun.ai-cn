---
import Logo from "@/icons/logo.svg";
const currentPath = Astro.url.pathname;
const buildDate = new Date();
const githubUrl = "https://github.com/midudev/canirun.ai";

const links = [
  { href: "/zh/playground", label: "体验" },
  { href: "/zh/compare", label: "对比" },
  { href: "/zh/tier", label: "分级" },
  { href: "/zh/docs", label: "文档" },
  { href: "/zh/why", label: "原理" },
];
---

<nav class="border-b border-edge/40">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-2.5 sm:px-6">
    <div class="flex items-center gap-2">
      <a href="/" class="flex items-center gap-1 font-pixel text-sm text-accent transition-colors hover:text-primary">
        <Logo class="size-3" />
        CanIRun.ai
      </a>
      <time id="build-time" class="font-mono text-xs text-primary/40" datetime={buildDate.toISOString()}>
        updated ...
      </time>
    </div>

    <div class="flex items-center gap-1 sm:gap-4">
      {/* Desktop links */}
      <div class="hidden items-center gap-4 font-mono text-[13px] sm:flex">
        {links.map(({ href, label }) => (
          <a
            href={href}
            class:list={[
              "transition-colors hover:text-accent",
              currentPath === href ? "text-primary" : "text-primary/70",
            ]}
          >
            [{label}]
          </a>
        ))}
      </div>

      <a
        href={githubUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="flex size-8 items-center justify-center text-primary/70 transition-colors hover:text-accent"
        aria-label="打开 GitHub 仓库"
      >
        <svg class="size-[18px]" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <polygon points="23 9 23 15 22 15 22 17 21 17 21 19 20 19 20 20 19 20 19 21 18 21 18 22 16 22 16 23 15 23 15 18 14 18 14 17 15 17 15 16 17 16 17 15 18 15 18 14 19 14 19 9 18 9 18 6 16 6 16 7 15 7 15 8 14 8 14 7 10 7 10 8 9 8 9 7 8 7 8 6 6 6 6 9 5 9 5 14 6 14 6 15 7 15 7 16 9 16 9 18 7 18 7 17 6 17 6 16 4 16 4 17 5 17 5 19 6 19 6 20 9 20 9 23 8 23 8 22 6 22 6 21 5 21 5 20 4 20 4 19 3 19 3 17 2 17 2 15 1 15 1 9 2 9 2 7 3 7 3 5 4 5 4 4 5 4 5 3 7 3 7 2 9 2 9 1 15 1 15 2 17 2 17 3 19 3 19 4 20 4 20 5 21 5 21 7 22 7 22 9 23 9"/>
        </svg>
      </a>

      {/* Theme toggle */}
      <button
        id="theme-toggle"
        class="flex size-8 items-center justify-center text-primary/70 transition-colors hover:text-accent cursor-pointer"
        aria-label="切换主题"
      >
        <svg class="theme-icon-sun size-[18px]" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 19a1 1 0 0 1 .993 .883l.007 .117v1a1 1 0 0 1 -1.993 .117l-.007 -.117v-1a1 1 0 0 1 1 -1z" /><path d="M18.313 16.91l.094 .083l.7 .7a1 1 0 0 1 -1.32 1.497l-.094 -.083l-.7 -.7a1 1 0 0 1 1.218 -1.567l.102 .07z" /><path d="M7.007 16.993a1 1 0 0 1 .083 1.32l-.083 .094l-.7 .7a1 1 0 0 1 -1.497 -1.32l.083 -.094l.7 -.7a1 1 0 0 1 1.414 0z" /><path d="M4 11a1 1 0 0 1 .117 1.993l-.117 .007h-1a1 1 0 0 1 -.117 -1.993l.117 -.007h1z" /><path d="M21 11a1 1 0 0 1 .117 1.993l-.117 .007h-1a1 1 0 0 1 -.117 -1.993l.117 -.007h1z" /><path d="M6.213 4.81l.094 .083l.7 .7a1 1 0 0 1 -1.32 1.497l-.094 -.083l-.7 -.7a1 1 0 0 1 1.217 -1.567l.102 .07z" /><path d="M19.107 4.893a1 1 0 0 1 .083 1.32l-.083 .094l-.7 .7a1 1 0 0 1 -1.497 -1.32l.083 -.094l.7 -.7a1 1 0 0 1 1.414 0z" /><path d="M12 2a1 1 0 0 1 .993 .883l.007 .117v1a1 1 0 0 1 -1.993 .117l-.007 -.117v-1a1 1 0 0 1 1 -1z" /><path d="M12 7a5 5 0 1 1 -4.995 5.217l-.005 -.217l.005 -.217a5 5 0 0 1 4.995 -4.783z" /></svg>
        <svg class="theme-icon-moon size-[18px]" viewBox="0 0 24 24" fill="currentColor" xmlns="http://www.w3.org/2000/svg"><path stroke="none" d="M0 0h24v24H0z" fill="none"/><path d="M12 1.992a10 10 0 1 0 9.236 13.838c.341 -.82 -.476 -1.644 -1.298 -1.31a6.5 6.5 0 0 1 -6.864 -10.787l.077 -.08c.551 -.63 .113 -1.653 -.758 -1.653h-.266l-.068 -.006l-.06 -.002z" /></svg>
      </button>

      {/* Mobile hamburger */}
      <button
        id="menu-toggle"
        class="flex size-8 items-center justify-center text-primary/70 transition-colors hover:text-accent sm:hidden"
        aria-label="打开菜单"
        aria-expanded="false"
      >
        <svg class="size-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
          <line x1="3" y1="5" x2="17" y2="5" />
          <line x1="3" y1="10" x2="17" y2="10" />
          <line x1="3" y1="15" x2="17" y2="15" />
        </svg>
      </button>
    </div>
  </div>
</nav>

{/* Fullscreen mobile menu */}
<div
  id="mobile-menu"
  class="fixed inset-0 z-50 flex flex-col bg-surface transition-all duration-300 ease-out"
  style="opacity:0;visibility:hidden;transform:translateY(-8px)"
  aria-hidden="true"
>
  <div class="flex items-center justify-between px-4 py-2.5">
    <a href="/" class="flex items-center gap-1 font-pixel text-sm text-accent transition-colors hover:text-primary">
      <Logo class="size-3" />
      CanIRun.ai
    </a>
    <button
      id="menu-close"
      class="flex size-8 items-center justify-center text-primary/70 transition-colors hover:text-accent"
      aria-label="关闭菜单"
    >
      <svg class="size-5" viewBox="0 0 20 20" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round">
        <line x1="4" y1="4" x2="16" y2="16" />
        <line x1="16" y1="4" x2="4" y2="16" />
      </svg>
    </button>
  </div>

  <div class="flex flex-1 flex-col items-center justify-center gap-6">
    {links.map(({ href, label }) => (
      <a
        href={href}
        class:list={[
          "mobile-menu-link font-mono text-2xl transition-colors hover:text-accent",
          currentPath === href ? "text-accent" : "text-primary/70",
        ]}
      >
        [{label}]
      </a>
    ))}
  </div>

</div>

<script>
  function initNavHeader() {
    const toggle = document.getElementById("menu-toggle");
    const menu = document.getElementById("mobile-menu");
    const close = document.getElementById("menu-close");
    if (!toggle || !menu || !close) return;

    function open() {
      menu!.style.visibility = "visible";
      requestAnimationFrame(() => {
        menu!.style.opacity = "1";
        menu!.style.transform = "translateY(0)";
      });
      toggle!.setAttribute("aria-expanded", "true");
      menu!.setAttribute("aria-hidden", "false");
      document.body.style.overflow = "hidden";
    }

    function shut() {
      menu!.style.opacity = "0";
      menu!.style.transform = "translateY(-8px)";
      toggle!.setAttribute("aria-expanded", "false");
      menu!.setAttribute("aria-hidden", "true");
      document.body.style.overflow = "";
      setTimeout(() => {
        menu!.style.visibility = "hidden";
      }, 300);
    }

    toggle.addEventListener("click", open);
    close.addEventListener("click", shut);

    menu.querySelectorAll("a").forEach((link) => {
      link.addEventListener("click", shut);
    });

    document.addEventListener("keydown", (e) => {
      if (e.key === "Escape" && menu!.getAttribute("aria-hidden") === "false") {
        shut();
      }
    });
  }

  function updateBuildTime() {
    const el = document.getElementById("build-time") as HTMLTimeElement | null;
    if (!el) return;

    const buildISO = el.getAttribute("datetime");
    if (!buildISO) return;

    const diffMs = Date.now() - new Date(buildISO).getTime();
    const mins = Math.floor(diffMs / 60_000);
    const hours = Math.floor(diffMs / 3_600_000);
    const days = Math.floor(diffMs / 86_400_000);

    let relative: string;
    if (days > 0) relative = `${days} 天前`;
    else if (hours > 0) relative = `${hours} 小时前`;
    else if (mins > 0) relative = `${mins} 分钟前`;
    else relative = "刚刚";

    el.textContent = `更新于 ${relative}`;
  }

  function initThemeToggle() {
    const btn = document.getElementById("theme-toggle");
    if (!btn) return;
    btn.addEventListener("click", () => {
      const isLight = document.documentElement.classList.toggle("light");
      localStorage.setItem("theme", isLight ? "light" : "dark");
      document.querySelector('meta[name="theme-color"]')
        ?.setAttribute("content", isLight ? "#ffffff" : "#08080a");
    });
  }

  document.addEventListener("astro:page-load", () => {
    updateBuildTime();
    initNavHeader();
    initThemeToggle();
  });
</script>

<style>
  .theme-icon-moon { display: none; }
  :global(html.light) .theme-icon-sun { display: none; }
  :global(html.light) .theme-icon-moon { display: block; }
</style>
